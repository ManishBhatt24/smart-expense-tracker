# ==========================================
# SUPABASE DATABASE CONFIGURATION
# ==========================================
# Get this from your Supabase Dashboard:
# Project Settings -> Database -> Connection String (URI)
# Make sure to replace [YOUR-PASSWORD] with your actual database password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ==========================================
# FLASK CONFIGURATION
# ==========================================
# A random secret key for session management
SECRET_KEY=your_super_secret_flask_key_here
